# Replace this with your actual Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@hostname/dbname?schema=public"

# The port your server should run on (usually provided by hosting platform like Heroku/Render)
PORT=5000

# Secret key for signing JSON Web Tokens (JWT) for admin authentication
JWT_SECRET="your_very_secure_random_string_here_for_jwt"

# Cloudinary Configuration for Image Uploads
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
